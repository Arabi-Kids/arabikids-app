# Frontend env (Vite only exposes VITE_-prefixed vars to the browser — never
# put a secret key here). Copy to frontend/.env and fill in.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push public key - must exactly match the root .env.example's
# VAPID_PUBLIC_KEY (see there for how to generate the pair).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
