# Root env — used by supabase/seed.mjs and by Netlify Functions (netlify/functions/*)
# when running `netlify dev` or after deploying. Copy to `.env` and fill in.

# Supabase (Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Stripe. Standard is USD $9.99/month, $89.99/year. Family is priced at 1.5x
# Standard (create these as separate Price objects in the Stripe Dashboard,
# not a quantity multiplier): $14.99/month, $134.99/year.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_ANNUAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_FAMILY_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_FAMILY_ANNUAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Enginemailer — find your API key at https://portal.enginemailer.com/Account/UserProfile.
# ENGINEMAILER_LIST_ID is a numeric "sub category" id (Enginemailer has no
# concept of a "list" — GetSubCategory lists what's available per account).
ENGINEMAILER_API_KEY=your-enginemailer-api-key
ENGINEMAILER_LIST_ID=your-subcategory-id

# Required for welcome/password-reset emails to actually send (not just list-add).
# Must be an address on a domain verified in Enginemailer: Account Settings >
# Domain Verification, add the domain, then add the DNS records they give you.
# Until this is set, welcome emails silently no-op and password reset falls
# back to Supabase's own default email.
ENGINEMAILER_SENDER_EMAIL=hello@yourdomain.com
ENGINEMAILER_SENDER_NAME=ArabiKids

# Used in success/cancel/return URLs built by the Netlify Functions
FRONTEND_URL=http://localhost:8888
