# Root env — used by supabase/seed.mjs and by Netlify Functions (netlify/functions/*)
# when running `netlify dev` or after deploying. Copy to `.env` and fill in.

# Supabase (Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Stripe (USD pricing: $9.99/month, $89.99/year)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_ANNUAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Enginemailer
ENGINEMAILER_API_KEY=your-enginemailer-api-key
ENGINEMAILER_API_URL=https://api.enginemailer.com/RESTAPI/v3.5
ENGINEMAILER_LIST_ID=your-list-id
ENGINEMAILER_WELCOME_TEMPLATE_ID=your-welcome-template-id

# Used in success/cancel/return URLs built by the Netlify Functions
FRONTEND_URL=http://localhost:8888
